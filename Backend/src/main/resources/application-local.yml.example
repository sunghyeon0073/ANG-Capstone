# 이 파일을 복사해서 application-local.yml 로 이름 변경 후 실제 값을 채우세요.
# application-local.yml 은 Git에 커밋되지 않습니다.

DB_URL: jdbc:mariadb://localhost:3306/ang_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME: root
DB_PASSWORD: your_db_password_here
JWT_SECRET: your-jwt-secret-key-at-least-256-bits-long
ADMIN_INIT_PASSWORD: Admin@1234
FILE_UPLOAD_DIR: uploads
OLLAMA_BASE_URL: http://localhost:11434
OLLAMA_MODEL: llama3.2
